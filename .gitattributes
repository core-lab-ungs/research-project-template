# Normalize text files across Windows, Linux, and macOS
* text=auto

# Repository documentation and configuration use LF
*.md text eol=lf
*.cff text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf

# Source code and scripts use LF
*.py text eol=lf
*.sh text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.java text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.r text eol=lf

# Windows-specific scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files must not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.bin binary
*.pcap binary
*.pcapng binary
